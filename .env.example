# Copy to `.env` and fill in secrets: `cp .env.example .env`
#
# Host-only dev (uvicorn / pytest): DATABASE_URL and REDIS_URL below use localhost.
# Docker Compose: `api` and `celery_worker` override these with in-network URLs
# (postgres:5432, redis:6379) — you do not need a second file for Docker.

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/revenue_db

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Frontend (Vite)
VITE_API_URL=http://localhost:8000
# Set to true with ENABLE_PHASE5 to show Forecasting / Profitability / Segments / FX in the UI
VITE_ENABLE_PHASE5=false
# Phase 6 governance UI (SSO login link needs VITE_DEFAULT_TENANT_ID in dev)
VITE_ENABLE_PHASE6=false
VITE_DEFAULT_TENANT_ID=

# App — min 16 characters
SECRET_KEY=change-me-to-a-long-random-secret
MAX_QUERY_ROWS=10000
QUERY_TIMEOUT_SECONDS=30
APP_ENV=development
DEBUG=true

# Natural language query (Phase 3). Set false in production if the NL stack is not deployed.
ENABLE_NL_QUERY=true
ENABLE_HUBSPOT=false

# Phase 6 — Enterprise SSO & governance (OIDC/SAML routes, audit export, operations summary)
ENABLE_SSO=true
PUBLIC_API_BASE_URL=http://127.0.0.1:8000
FRONTEND_PUBLIC_BASE_URL=http://localhost:5173
# OIDC token exchange (env-only secret; not stored in DB)
OIDC_CLIENT_SECRET=
AUDIT_EXPORT_MAX_ROWS=500000

# Phase 5 — forecast, cost, FX, segments (disabled by default; Phase 1–4 unchanged when off)
ENABLE_PHASE5=false
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:8000/api/v1/integrations/hubspot/oauth/callback
HUBSPOT_FRONTEND_REDIRECT_BASE=http://localhost:5173/integrations/hubspot
ALLOW_REGISTRATION=true

# Ingestion: sync when file smaller than threshold; async otherwise (tune per task)
INGEST_SYNC_MAX_BYTES=5242880
INGEST_ASYNC_MIN_BYTES=5242880
