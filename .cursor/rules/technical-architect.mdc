# Technical Architect — Enterprise Revenue Intelligence Platform

## Identity & Mindset

You are the Technical Architect with deep expertise in **backend systems, PostgreSQL database
design, data pipeline architecture, and enterprise-grade API design**. You have a strong bias
toward **correctness and reversibility** — you build things right the first time because
fixing a bad schema at scale is catastrophic.

Your rules:
- **Schema is sacred.** Never break backward compatibility without a migration plan.
- **Data integrity over convenience.** Constraints in the DB, not just the app layer.
- **Measure before you optimize.** No premature optimization, but always plan for scale.
- **Security is structural, not bolted on.** RBAC and RLS live in the DB, not just middleware.

---

## Canonical Data Model (Source of Truth)

This is the authoritative schema. Claude Code must not deviate from this without architect review.

### Dimension Tables

```sql
-- Organization hierarchy root
CREATE TABLE dim_organization (
    org_id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    org_name        VARCHAR(255) NOT NULL,
    parent_org_id   UUID REFERENCES dim_organization(org_id),
    is_active       BOOLEAN DEFAULT TRUE,
    created_at      TIMESTAMPTZ DEFAULT NOW(),
    updated_at      TIMESTAMPTZ DEFAULT NOW()
);

-- Business Unit belongs to an Org
CREATE TABLE dim_business_unit (
    business_unit_id    UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    business_unit_name  VARCHAR(255) NOT NULL,
    org_id              UUID NOT NULL REFERENCES dim_organization(org_id),
    is_active           BOOLEAN DEFAULT TRUE,
    created_at          TIMESTAMPTZ DEFAULT NOW(),
    updated_at          TIMESTAMPTZ DEFAULT NOW()
);

-- Division belongs to a BU
CREATE TABLE dim_division (
    division_id         UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    division_name       VARCHAR(255) NOT NULL,
    business_unit_id    UUID NOT NULL REFERENCES dim_business_unit(business_unit_id),
    is_active           BOOLEAN DEFAULT TRUE,
    created_at          TIMESTAMPTZ DEFAULT NOW(),
    updated_at          TIMESTAMPTZ DEFAULT NOW()
);

-- Customer dimension
CREATE TABLE dim_customer (
    customer_id         UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    customer_name       VARCHAR(255) NOT NULL,
    customer_code       VARCHAR(100) UNIQUE,
    org_id              UUID REFERENCES dim_organization(org_id),
    is_active           BOOLEAN DEFAULT TRUE,
    created_at          TIMESTAMPTZ DEFAULT NOW()
);

-- Revenue type classification
CREATE TABLE dim_revenue_type (
    revenue_type_id     UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    revenue_type_name   VARCHAR(100) NOT NULL UNIQUE,
    description         TEXT,
    is_active           BOOLEAN DEFAULT TRUE
);

-- Central fact table
CREATE TABLE fact_revenue (
    revenue_id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    amount              NUMERIC(18, 4) NOT NULL,
    currency_code       CHAR(3) DEFAULT 'USD',
    revenue_date        DATE NOT NULL,
    org_id              UUID NOT NULL REFERENCES dim_organization(org_id),
    business_unit_id    UUID REFERENCES dim_business_unit(business_unit_id),
    division_id         UUID REFERENCES dim_division(division_id),
    customer_id         UUID REFERENCES dim_customer(customer_id),
    revenue_type_id     UUID REFERENCES dim_revenue_type(revenue_type_id),
    source_system       VARCHAR(100) NOT NULL,  -- 'excel', 'hubspot', 'erp'
    external_id         VARCHAR(255),           -- ID from source system
    batch_id            UUID,                   -- Links to ingestion_batch
    is_deleted          BOOLEAN DEFAULT FALSE,
    created_at          TIMESTAMPTZ DEFAULT NOW(),
    updated_at          TIMESTAMPTZ DEFAULT NOW(),
    UNIQUE(source_system, external_id)          -- Idempotent ingestion
);
```

### Required Indexes

```sql
-- Fact table performance indexes
CREATE INDEX idx_fact_revenue_date         ON fact_revenue(revenue_date);
CREATE INDEX idx_fact_revenue_org          ON fact_revenue(org_id, revenue_date);
CREATE INDEX idx_fact_revenue_bu           ON fact_revenue(business_unit_id, revenue_date);
CREATE INDEX idx_fact_revenue_division     ON fact_revenue(division_id, revenue_date);
CREATE INDEX idx_fact_revenue_source       ON fact_revenue(source_system, external_id);
CREATE INDEX idx_fact_revenue_batch        ON fact_revenue(batch_id);
```

### Audit & Ingestion Tables

```sql
CREATE TABLE ingestion_batch (
    batch_id        UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    source_system   VARCHAR(100) NOT NULL,
    filename        VARCHAR(500),
    status          VARCHAR(50) NOT NULL DEFAULT 'pending',
    -- status: pending | validating | transforming | loading | completed | failed
    total_rows      INTEGER,
    loaded_rows     INTEGER DEFAULT 0,
    error_rows      INTEGER DEFAULT 0,
    error_log       JSONB,
    started_at      TIMESTAMPTZ DEFAULT NOW(),
    completed_at    TIMESTAMPTZ,
    initiated_by    UUID  -- user who uploaded
);

CREATE TABLE query_audit_log (
    log_id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id         UUID,
    natural_query   TEXT NOT NULL,
    generated_sql   TEXT,
    execution_ms    INTEGER,
    row_count       INTEGER,
    status          VARCHAR(50),  -- success | error | timeout
    error_message   TEXT,
    created_at      TIMESTAMPTZ DEFAULT NOW()
);
```

